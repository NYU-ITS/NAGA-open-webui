    {
      "id": 11,
      "type": "timeseries",
      "title": "Frontend Checks Needing Attention",
      "description": "Failures/errors over time, split by GitHub vs OpenShift and by check type.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (environment, source, status) (ai_tutor_quality_checks_total{repository=\"NAGA-open-webui\",source=~\"frontend_unit|playwright_ui\",status=~\"failed|error\"} and on(environment,repository,source,run_id) topk by(environment,repository,source) (1, ai_tutor_quality_source_last_run_timestamp_seconds{repository=\"NAGA-open-webui\",source=~\"frontend_unit|playwright_ui\"}))",
          "legendFormat": "{{environment}} {{source}} {{status}}",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 12,
      "type": "table",
      "title": "Latest Frontend Check Details",
      "description": "Individual checks from the latest GitHub and OpenShift frontend quality runs. OpenShift scheduled checks currently run Vitest only; GitHub runs Vitest and mocked Playwright.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "targets": [
        {
          "refId": "A",
          "expr": "last_over_time(ai_tutor_quality_check_duration_seconds{repository=\"NAGA-open-webui\",source=~\"frontend_unit|playwright_ui\"}[$__range]) and on(environment,repository,source,run_id) topk by(environment,repository,source) (1, last_over_time(ai_tutor_quality_source_last_run_timestamp_seconds{repository=\"NAGA-open-webui\",source=~\"frontend_unit|playwright_ui\"}[$__range]))",
          "format": "table",
          "instant": true,
          "range": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "align": "auto",
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              },
              {
                "id": "displayName",
                "value": "Duration"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "run_id"
            },
            "properties": [
              {
                "id": "unit",
                "value": "none"
              },
              {
                "id": "displayName",
                "value": "Run ID"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "commit_sha"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Commit"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "classname"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Test file"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "name"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Check"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "source"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Check type"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "environment"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Where"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "status"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Result"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "countRows": false,
          "fields": ""
        }
      }
    }
